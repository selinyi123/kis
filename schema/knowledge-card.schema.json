{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kis.local/schema/knowledge-card-0.3.1.json",
  "title": "KnowledgeCard",
  "description": "KIS unified knowledge asset. v0.3.1 frozen schema. Unknown fields are rejected (additionalProperties:false). 0.2.x: multi-source ingest + provenance + extraction. 0.3.0: optional `derived` AI layer (KIS-013). 0.3.1: human review gate (KIS-014) — lifecycle.state gains reviewed/canonical/rejected/deferred (lifecycle.state IS the lifecycle status), plus an optional `review` record. canonical is produced ONLY by an explicit human command; review writes ONLY lifecycle + review, never source/content/enrichment/linkage/safety/derived.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "content_hash", "source", "content", "enrichment", "linkage", "lifecycle", "safety"],
  "properties": {
    "schema_version": { "type": "string", "enum": ["0.3.1"] },
    "id": { "type": "string", "description": "Deterministic stable id kc_<16hex> = sha256(source_type|normalized_url). Idempotent across re-runs." },
    "content_hash": { "type": "string", "description": "sha256 hex of content fingerprint; changes when source content changes (update tracking)." },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_type", "url", "source_id", "captured_at"],
      "properties": {
        "source_type": { "type": "string", "enum": ["github_star", "web_bookmark", "web_clip", "clipboard", "project_event", "manual", "rss"] },
        "url": { "type": "string" },
        "source_id": { "type": "string", "description": "url_hash — 16hex of normalized_url." },
        "captured_at": { "type": "string" },
        "raw_ref": { "type": "string" },
        "folder_path": { "type": "string" },
        "raw_title": { "type": "string" },
        "normalized_url": { "type": "string" },
        "import_batch_id": { "type": "string" },
        "site_name": { "type": "string" },
        "http_status": { "type": "integer" },
        "fetched_at": { "type": "string" },
        "fetch_error": { "type": "string" },
        "extraction_engine": { "type": "string", "enum": ["stdlib", "crawl4ai"] },
        "extraction_status": { "type": "string", "enum": ["success", "fallback", "failed"] },
        "extraction_error": { "type": "string" }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body_md", "lang"],
      "properties": {
        "title": { "type": "string" },
        "body_md": { "type": "string" },
        "lang": { "type": "string" },
        "description": { "type": "string" },
        "text_preview": { "type": "string" },
        "clean_markdown": { "type": "string" },
        "structured_data": { "type": "object" },
        "media": { "type": "array", "items": { "type": "object" } }
      }
    },
    "enrichment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_level", "value_score", "value_level", "authority"],
      "properties": {
        "summary": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "value_score": { "type": "integer" },
        "value_level": { "type": "string", "enum": ["cold", "warming", "usable", "ready"] },
        "evidence_level": { "type": "string", "enum": ["source", "heuristic", "llm", "user_confirmed"] },
        "authority": { "type": "string", "enum": ["source", "derived"] }
      }
    },
    "linkage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projects", "related_cards", "wikilinks"],
      "properties": {
        "projects": { "type": "array", "items": { "type": "string" } },
        "related_cards": { "type": "array", "items": { "type": "string" } },
        "wikilinks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "created_at", "updated_at", "version"],
      "properties": {
        "state": { "type": "string", "enum": ["inbox", "cleaned", "enriched", "linked", "archived", "stale", "quarantine", "reviewed", "canonical", "rejected", "deferred"] },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" },
        "last_checked_at": { "type": "string" },
        "version": { "type": "integer" }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secret_redacted", "injection_scanned", "sensitivity"],
      "properties": {
        "secret_redacted": { "type": "boolean" },
        "injection_scanned": { "type": "boolean" },
        "sensitivity": { "type": "string", "enum": ["public", "internal", "blocked"] }
      }
    },
    "derived": {
      "type": "object",
      "description": "Optional AI-enrichment layer (KIS-013). Never present until enrichment runs; never mutates source/content/enrichment.",
      "additionalProperties": false,
      "required": ["value_score", "value_level", "reason_tags", "project_relevance", "next_action", "review_flags", "processing_status", "generator"],
      "properties": {
        "ai_summary": { "type": "string" },
        "value_score": { "type": "number" },
        "value_level": { "type": "string", "enum": ["cold", "warm", "hot", "critical"] },
        "reason_tags": { "type": "array", "items": { "type": "string" } },
        "project_relevance": {
          "type": "object",
          "additionalProperties": false,
          "required": ["clipvault", "kis", "dpms", "prompt_engine", "visual_prompt_library", "trading_research"],
          "properties": {
            "clipvault": { "type": "number" },
            "kis": { "type": "number" },
            "dpms": { "type": "number" },
            "prompt_engine": { "type": "number" },
            "visual_prompt_library": { "type": "number" },
            "trading_research": { "type": "number" }
          }
        },
        "next_action": { "type": "string", "enum": ["ignore", "archive", "read", "test", "integrate", "monitor"] },
        "review_flags": { "type": "array", "items": { "type": "string" } },
        "processing_status": { "type": "string", "enum": ["pending", "heuristic", "llm_generated", "failed"] },
        "generated_at": { "type": "string" },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["mode", "input_hash"],
          "properties": {
            "mode": { "type": "string", "enum": ["heuristic", "llm", "auto"] },
            "provider": { "type": "string" },
            "model": { "type": "string" },
            "prompt_hash": { "type": "string" },
            "input_hash": { "type": "string" },
            "output_hash": { "type": "string" },
            "error": { "type": "string" }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "description": "Human review record (KIS-014). Present once a review decision is made. canonical requires an explicit human approve command.",
      "additionalProperties": false,
      "required": ["decision", "reason", "reviewer", "reviewed_at", "previous_status", "next_status", "source_hash", "derived_hash", "review_hash"],
      "properties": {
        "decision": { "type": "string", "enum": ["reviewed", "approve_canonical", "archive", "defer", "reject"] },
        "reason": { "type": "string" },
        "reviewer": { "type": "string" },
        "reviewed_at": { "type": "string" },
        "previous_status": { "type": "string" },
        "next_status": { "type": "string" },
        "source_hash": { "type": "string" },
        "derived_hash": { "type": "string" },
        "review_hash": { "type": "string" }
      }
    }
  }
}
